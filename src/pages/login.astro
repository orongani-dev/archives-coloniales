---
import Nav from '../components/Nav.astro';
---

<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Connexion - Archives Coloniales</title>
</head>
<body>
  <Nav />
  <h1>Connexion / Inscription</h1>
  <p>Cliquez sur le bouton ci-dessous pour vous connecter ou créer un compte.</p>
  <div id="identity-btn"></div>
</body>
</html>

<script>
  // Charger le script Identity manuellement
  var script = document.createElement('script');
  script.src = 'https://identity.netlify.com/v1/netlify-identity-widget.js';
  script.onload = function() {
    netlifyIdentity.init({
      container: '#identity-btn'
    });
  };
  document.head.appendChild(script);
</script>