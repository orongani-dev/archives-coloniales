---
import Nav from '../components/Nav.astro';
---

<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Connexion - Archives Coloniales</title>
</head>
<body>
  <Nav />
  <h1>Connexion / Inscription</h1>
  <p>Entrez votre email pour recevoir un lien de connexion.</p>
  <form id="login-form">
    <input type="email" id="email" placeholder="votre@email.com" required style="width:300px; padding:8px;" />
    <button type="submit" style="padding:8px 20px;">Envoyer le lien</button>
  </form>
  <p id="message" style="margin-top:10px;"></p>
</body>
</html>

<script>
  document.getElementById('login-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    var email = document.getElementById('email').value;
    var msg = document.getElementById('message');
    msg.textContent = 'Envoi en cours...';

    try {
      var response = await fetch('/.netlify/functions/send-login-link', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email })
      });
      
      if (response.ok) {
        msg.innerHTML = '<span style="color:green;">✅ Lien envoyé ! Vérifiez votre boîte mail (et les spams).</span>';
      } else {
        var data = await response.json();
        msg.innerHTML = '<span style="color:red;">❌ ' + (data.error || 'Erreur') + '</span>';
      }
    } catch (err) {
      msg.innerHTML = '<span style="color:red;">❌ Erreur réseau.</span>';
    }
  });
</script>