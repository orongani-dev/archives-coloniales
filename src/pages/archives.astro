---
import Nav from '../components/Nav.astro';
---

<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Archives disponibles</title>
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  <style>
    .archive-card {
      border: 1px solid #ccc;
      padding: 15px;
      margin: 10px 0;
      border-radius: 5px;
      background: #fafafa;
    }
    .archive-card h3 {
      margin-top: 0;
      color: #333;
    }
    .archive-card .meta {
      font-size: 0.9em;
      color: #666;
    }
  </style>
</head>
<body>
  <Nav />
  <h1>Archives disponibles</h1>
  <p><a href="/soumettre">Soumettre une correction</a></p>
  
  <div id="archive-list">
    <p>Chargement en cours...</p>
  </div>
</body>
</html>

<script>
  if (window.netlifyIdentity) {
    window.netlifyIdentity.on('init', function(user) {
      if (!user) {
        window.location.href = '/login';
      } else {
        chargerArchives(user);
      }
    });
    window.netlifyIdentity.init();
  }

  async function chargerArchives(user) {
    var container = document.getElementById('archive-list');
    container.innerHTML = '<p>Chargement des archives...</p>';

    try {
      var response = await fetch('/.netlify/functions/getArchives', {
        headers: {
          Authorization: 'Bearer ' + user.token.access_token
        }
      });

      if (!response.ok) {
        throw new Error('Erreur lors du chargement');
      }

      var data = await response.json();
      var archives = data.list || data;

      if (archives.length === 0) {
        container.innerHTML = '<p>Aucune archive trouvée pour le moment.</p>';
        return;
      }

      var html = '';
      archives.forEach(function(archive) {
        html += '<div class="archive-card">';
        html += '<h3>' + (archive.Titre || 'Sans titre') + '</h3>';
        html += '<p class="meta">Date : ' + (archive.Date || 'Non daté') + ' | Catégorie : ' + (archive.Categorie || 'Autre') + '</p>';
        html += '<p>' + (archive.Contenu || '').substring(0, 200) + '...</p>';
        html += '<p><strong>Mots-clés :</strong> ' + (archive.MotsCles || 'Aucun') + '</p>';
        html += '</div>';
      });

      container.innerHTML = html;
    } catch (error) {
      container.innerHTML = '<p style="color: red;">Erreur : ' + error.message + '</p>';
    }
  }
</script>