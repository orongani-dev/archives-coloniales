---
import Nav from '../components/Nav.astro';
---

<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Archives disponibles</title>
  <style>
    .archive-card {
      border: 1px solid #ccc;
      padding: 15px;
      margin: 10px 0;
      border-radius: 5px;
      background: #fafafa;
    }
    .archive-card h3 { margin-top: 0; color: #333; }
    .archive-card .meta { font-size: 0.9em; color: #666; }
  </style>
</head>
<body>
  <Nav />
  <h1>Archives disponibles</h1>
  <div id="archive-list"><p>Vérification de l'accès...</p></div>
</body>
</html>

<script>
  // Récupérer le token dans l'URL (mis par Netlify après clic sur lien magique)
  var hash = window.location.hash;
  if (hash.includes('access_token')) {
    // Stocker le token
    var params = new URLSearchParams(hash.substring(1));
    var token = params.get('access_token');
    localStorage.setItem('nf_token', token);
    // Nettoyer l'URL
    window.location.hash = '';
  }

  var token = localStorage.getItem('nf_token');

  if (!token) {
    window.location.href = '/login';
  } else {
    chargerArchives();
  }

  async function chargerArchives() {
    var container = document.getElementById('archive-list');
    container.innerHTML = '<p>Chargement des archives...</p>';
    try {
      var response = await fetch('/.netlify/functions/getArchives', {
        headers: { 'Authorization': 'Bearer ' + token }
      });
      if (!response.ok) {
        localStorage.removeItem('nf_token');
        window.location.href = '/login';
        return;
      }
      var data = await response.json();
      var archives = data.list || data;
      if (!archives || archives.length === 0) {
        container.innerHTML = '<p>Aucune archive trouvée.</p>';
        return;
      }
      var html = '';
      archives.forEach(function(a) {
        html += '<div class="archive-card">';
        html += '<h3>' + (a.Titre || 'Sans titre') + '</h3>';
        html += '<p class="meta">Date : ' + (a.Date || 'Non daté') + ' | Catégorie : ' + (a.Categorie || 'Autre') + '</p>';
        html += '<p>' + (a.Contenu || '').substring(0, 200) + '...</p>';
        html += '<p><strong>Mots-clés :</strong> ' + (a.MotsCles || 'Aucun') + '</p>';
        html += '</div>';
      });
      container.innerHTML = html;
    } catch (error) {
      container.innerHTML = '<p style="color:red;">Erreur : ' + error.message + '</p>';
    }
  }
</script>